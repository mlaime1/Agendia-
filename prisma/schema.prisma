generator client {
  provider = "prisma-client-js"
  engine = "binary"
}

datasource db {
  provider = "postgresql"
}

enum trip_type_enum {
  ida
  ida_y_vuelta @map("ida y vuelta")
  especial
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model clients {
  id            BigInt      @id(map: "cliente_pkey") @default(autoincrement())
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  nombre        String      @db.VarChar
  phone         Decimal     @db.Decimal
  billing_cycle String      @db.VarChar
  rates         rates[]
  routes        routes[]
  summaries     summaries[]
  trips         trips[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model rates {
  id              BigInt    @id @default(autoincrement())
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  client_id       BigInt?
  route_id        BigInt?
  base_price      Decimal   @db.Decimal
  surcharge_price Decimal?  @db.Decimal
  start_date      DateTime? @db.Date
  end_date        DateTime? @db.Date
  clients         clients?  @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  routes          routes?   @relation(fields: [route_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips           trips[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model route_stops {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  address    String?  @db.VarChar
  stop_order Decimal? @db.Decimal
  route_id   BigInt?
  routes     routes?  @relation(fields: [route_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model routes {
  id          BigInt        @id @default(autoincrement())
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  name        String?       @db.VarChar
  client_id   BigInt?
  rates       rates[]
  route_stops route_stops[]
  clients     clients?      @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips       trips[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model summaries {
  id           BigInt    @id @default(autoincrement())
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  client_id    BigInt
  driver_id    BigInt
  period_start DateTime  @db.Date
  period_end   DateTime  @db.Date
  period_type  String    @db.VarChar
  total_trips  Int       @default(0)
  total_amount Decimal   @default(0) @db.Decimal
  status       String    @default("draft") @db.VarChar
  sent_at      DateTime? @db.Timestamptz(6)
  paid_at      DateTime? @db.Timestamptz(6)
  archived_at  DateTime? @db.Timestamptz(6)
  whatsapp_msg String?
  notes        String?   @db.VarChar
  clients      clients   @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users        users     @relation(fields: [driver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips        trips[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model trips {
  id               BigInt     @id @default(autoincrement())
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  user_id          BigInt
  client_id        BigInt
  route_id         BigInt
  rate_id          BigInt
  trip_date        DateTime   @db.Timestamp(6)
  trip_type        trip_type_enum
  final_price      Decimal    @db.Decimal
  has_surcharge    Boolean    @default(false)
  surcharge_reason String?    @db.VarChar
  special_type     String?    @db.VarChar
  notes            String?    @db.VarChar
  summary_id       BigInt?
  clients          clients    @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rates            rates      @relation(fields: [rate_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  routes           routes     @relation(fields: [route_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  summaries        summaries? @relation(fields: [summary_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id         BigInt      @id(map: "user_pkey") @default(autoincrement())
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  name       String      @db.VarChar
  email      String      @db.VarChar
  alias      String?     @db.VarChar
  summaries  summaries[]
  trips      trips[]
}
